{
    // IntelliSense를 사용하여 가능한 특성에 대해 알아보세요.
    // 기존 특성에 대한 설명을 보려면 가리킵니다.
    // 자세한 내용을 보려면 https://go.microsoft.com/fwlink/?linkid=830387을(를) 방문하세요.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "doc_converter: 문서 변환 (로컬 OSS)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/doc_converter/convert.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tools/doc_converter",
            "python": "${workspaceFolder}/tools/doc_converter/.venv/Scripts/python.exe",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            },
            "justMyCode": true
        },
        {
            "name": "doc_converter: 문서 변환 (DoXA API, 사내)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/doc_converter/doxa_convert.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tools/doc_converter",
            "python": "${workspaceFolder}/tools/doc_converter/.venv/Scripts/python.exe",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            },
            "justMyCode": true
        },
        {
            "name": "doc_converter: DoXA 스모크 테스트",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/doc_converter/doxa_smoke_test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tools/doc_converter",
            "python": "${workspaceFolder}/tools/doc_converter/.venv/Scripts/python.exe",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            }
        },
        {
            "name": "doc_converter: 두 결과 비교",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/doc_converter/compare_outputs.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/tools/doc_converter",
            "python": "${workspaceFolder}/tools/doc_converter/.venv/Scripts/python.exe",
            "env": {
                "PYTHONIOENCODING": "utf-8"
            }
        }
    ]
}
