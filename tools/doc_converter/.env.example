# DoXA 토큰 저장 템플릿.
# 이 파일을 `.env` 로 복사 후 실제 토큰을 넣으세요.
# `.env` 는 .gitignore 에 포함되어 있어 commit 되지 않습니다.
#
# 사용법:
#   1) 이 파일을 복사:  copy .env.example .env
#   2) `.env` 편집해 아래 값 채우기
#   3) 이후 모든 스크립트가 자동 로드 (매번 set DOXA_TOKEN 불필요)

# 필수 — AI Asset Hub (https://aia.sec.samsung.net) 에서 발급
DOXA_TOKEN=

# 선택 — 기본값: https://doxa.sec.samsung.net
# 네트워크 존에 따라 iPaaS 사용이 필요할 수 있음 (doxa_smoke_test.py 로 확인):
#   iPaaS 사내 : https://ipaas-sca.sec.samsung.net/sec/kr/doxa_parser_document_v2/1.0
#   iPaaS 외부 : https://sca.ipaas.samsung.com/sec/kr/doxa_parser_document_v2/1.0
DOXA_URL=

# 선택 — iPaaS 게이트웨이 경유 시 필요
IPAAS_TOKEN=
